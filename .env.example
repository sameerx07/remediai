# ---------------------------------------------------------------
# RemediAI — Environment Variables
# Copy this file to .env and fill in your non-production values.
# NEVER commit .env — it is in .gitignore.
# All production secrets are managed via Azure Key Vault.
# ---------------------------------------------------------------

# --- Azure Identity -------------------------------------------
# Leave blank when using Managed Identity (AKS / local az login).
# Set only when using a service principal for local dev.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Azure Monitor / Application Insights ---------------------
AZURE_MONITOR_WORKSPACE_ID=
APPINSIGHTS_CONNECTION_STRING=

# --- Azure Service Bus ----------------------------------------
AZURE_SERVICEBUS_NAMESPACE=
AZURE_SERVICEBUS_TOPIC=incident-events
AZURE_SERVICEBUS_SUBSCRIPTION=agent-worker

# --- Azure OpenAI ---------------------------------------------
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Azure AI Search ------------------------------------------
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX=remediai-rag

# --- Azure Key Vault ------------------------------------------
AZURE_KEYVAULT_URL=

# --- Azure DevOps ---------------------------------------------
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-org
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=

# --- PostgreSQL -----------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=remediai
POSTGRES_USER=remediai
POSTGRES_PASSWORD=change_me_locally

# --- Redis ----------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Application ----------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
CORRELATION_ID_HEADER=X-Correlation-ID

# --- Ingestion ------------------------------------------------
INGESTION_POLL_INTERVAL_SECONDS=60
INGESTION_LOOKBACK_MINUTES=10
